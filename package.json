{
  "name": "signal-forge",
  "version": "0.1.0",
  "description": "Robust extraction of structured signals from messy unstructured text",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "extract": "tsx src/cli.ts",
    "eval": "tsx evals/run.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "dotenv": "^16.4.5",
    "mailparser": "^3.7.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.4",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
